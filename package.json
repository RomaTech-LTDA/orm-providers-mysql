{
    "name": "@romatech/orm-providers-mysql",
    "version": "2.0.0",
    "description": "MySQL / MariaDB provider for RomaTech ORM",
    "author": "RomaTech/Leandro Romanelli",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/RomaTech-LTDA/orm-providers-mysql"
    },
    "homepage": "https://github.com/RomaTech-LTDA/orm-providers-mysql#readme",
    "bugs": {
        "url": "https://github.com/RomaTech-LTDA/orm-providers-mysql/issues"
    },
    "keywords": [
        "orm",
        "mysql",
        "mariadb",
        "romatech",
        "database",
        "typescript"
    ],
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "clean": "rimraf dist",
        "build": "npm run clean && tsc",
        "watch": "tsc --watch"
    },
