        "mysql2": "^3.6.0"
    },
    "peerDependencies": {
        "@romatech/orm": "^2.0.0"
    },
    "devDependencies": {
        "@romatech/orm": "^2.0.0",
        "@types/node": "^26.1.0",
        "rimraf": "^6.0.1",
        "typescript": "^5.9.3"
    },
    "engines": {
        "node": ">=18"
    },
    "publishConfig": {
        "access": "public"
    }
